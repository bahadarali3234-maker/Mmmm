{
  "entities": {
    "ChatTurn": {
      "title": "Chat Turn",
      "description": "A single turn in a conversation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "duration": { "type": "number" },
        "serverTime": { "type": "object", "format": "timestamp" }
      },
      "required": ["userId", "role", "text", "timestamp"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Profile information for a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "voice": { "type": "string" },
        "storeName": { "type": "string" },
        "memory": { "type": "string" }
      }
    },
    "Feedback": {
      "title": "Conversation Feedback",
      "description": "User feedback on specific responses or the overall session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sessionId": { "type": "string" },
        "rating": { "type": "string", "enum": ["up", "down"] },
        "comment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "timestamp"]
    }
  },
  "firestore": {
    "chat_history": {
      "schema": "ChatTurn",
      "description": "Collection of all chat turns across all users."
    },
    "user_profiles": {
      "schema": "UserProfile",
      "description": "User profile documents stored by UID."
    },
    "feedback": {
      "schema": "Feedback",
      "description": "User feedback entries."
    }
  }
}

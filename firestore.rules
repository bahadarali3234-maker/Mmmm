rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidChatTurn(data) {
      return data.keys().hasAll(['userId', 'role', 'text', 'timestamp'])
        && data.keys().size() <= 6
        && data.userId == request.auth.uid
        && data.role in ['user', 'model']
        && data.text is string && data.text.size() <= 10000
        && data.timestamp is number
        && (data.get('duration', 0) is number)
        && (data.get('serverTime', request.time) == request.time);
    }

    function isValidUserProfile(data) {
      return data.keys().size() <= 4
        && (!data.keys().hasAny(['name']) || (data.name is string && data.name.size() <= 100))
        && (!data.keys().hasAny(['voice']) || (data.voice is string && data.voice.size() <= 50))
        && (!data.keys().hasAny(['storeName']) || (data.storeName is string && data.storeName.size() <= 200))
        && (!data.keys().hasAny(['memory']) || (data.memory is string && data.memory.size() <= 10000));
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'rating', 'timestamp'])
        && data.keys().size() <= 6
        && data.userId == request.auth.uid
        && data.rating in ['up', 'down']
        && (data.get('comment', '') is string && data.get('comment', '').size() <= 1000)
        && (data.get('sessionId', '') is string && data.get('sessionId', '').size() <= 128);
    }

    // Collection Rules
    match /chat_history/{id} {
      allow create: if isOwner(incoming().userId) && isValidChatTurn(incoming()) && isValidId(id);
      allow delete: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(resource.data.userId);
    }

    match /user_profiles/{userId} {
      allow read: if isOwner(userId) || userId == 'guest_user';
      allow create: if (isOwner(userId) || userId == 'guest_user') && isValidUserProfile(incoming()) && isValidId(userId);
      allow update: if (isOwner(userId) || userId == 'guest_user') && isValidUserProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'voice', 'storeName', 'memory']);
    }

    match /feedback/{id} {
      allow create: if isOwner(incoming().userId) && isValidFeedback(incoming()) && isValidId(id);
      allow delete: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isOwner(resource.data.userId);
    }
  }
}
